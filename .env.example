# ============================================================================
# Prompt Studio — environment. Copy to .env.local and fill in as you go.
# The app RUNS WITH NO VALUES SET (mock catalog + mock providers + dev billing).
# Real DB/keys drop in here with no code changes (§1, §13).
# ============================================================================

# ---- Data source (unset => local mock catalog) -----------------------------
DATABASE_URL=mysql://USER:PASS@HOST:3306/category_template
EXISTING_API_BASE_URL=

# ---- Media (resolves relative *_path / *_image columns) --------------------
MEDIA_BASE_URL=https://cdn.example.com/

# ---- Auth.js (NextAuth) ----------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Cashfree (INR). Unset => dev test-mode (non-prod only) ----------------
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox              # sandbox | production
CASHFREE_API_VERSION=2023-08-01
CASHFREE_DEFAULT_PHONE=9999999999 # Cashfree requires a phone; collect a real one at checkout

# ---- Runware (AI generation — SERVER ONLY, never exposed to browser) -------
RUNWARE_API_KEY=
RUNWARE_API_URL=https://api.runware.ai/v1
RUNWARE_WS_URL=wss://ws-api.runware.ai/v1
RUNWARE_WEBHOOK_SECRET=
RUNWARE_MODEL_IMAGE=placeholder:image@1   # TBD — owner will supply real AIR ID
RUNWARE_MODEL_VIDEO=placeholder:video@1   # TBD — owner will supply real AIR ID

# ---- Coin costs (spend) ----------------------------------------------------
COIN_COST_VIDEO=10
COIN_COST_IMAGE=5
COIN_COST_FILTER=3
COIN_COST_TOOL=3

# ---- Plan coin grants ------------------------------------------------------
PLAN_COINS_WEEKLY=50
PLAN_COINS_MONTHLY=150
PLAN_COINS_YEARLY=1200

# ---- Plan prices (INR) -----------------------------------------------------
PLAN_PRICE_WEEKLY=49
PLAN_PRICE_MONTHLY=149
PLAN_PRICE_YEARLY=1199

# ---- Video generation defaults (mapped to model caps server-side) ----------
VIDEO_DEFAULT_DURATION=6
VIDEO_DEFAULT_RESOLUTION=480

# ---- Free unlock quota (logged-in free users / day) ------------------------
FREE_UNLOCKS_PER_DAY=3

# ---- Generation rate limit (per user / minute) -----------------------------
GENERATION_RATE_PER_MIN=12
